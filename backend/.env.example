# ---- Servidor ----
# Puerto donde escucha la API
PORT=3000
# Origen permitido para CORS (URL del frontend)
FRONTEND_URL=http://localhost:5173

# ---- Base de datos (PostgreSQL) ----
# Opción A: URL completa (Railway la provee así)
# DATABASE_URL=postgresql://usuario:password@localhost:5432/splitapp
# Opción B: variables sueltas (se usan si DATABASE_URL no está definida)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=splitapp
# SSL para la conexión (true en Railway/producción, false local)
DB_SSL=false

# ---- Autenticación ----
# Secret para firmar JWT. Generar uno real: openssl rand -hex 32
JWT_SECRET=cambiame-por-un-secret-largo-y-aleatorio
# Vencimiento del token
JWT_EXPIRES_IN=7d
